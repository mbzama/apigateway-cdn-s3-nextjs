# AWS Configuration
aws_region = "us-east-1"

# Project Configuration
environment    = "dev"
project_name   = "app"
domain_name    = "app-dev.zamait.in"
certificate_domain = "*.zamait.in"

# S3 Configuration
s3_bucket_versioning = true

# CloudFront Configuration
cloudfront_price_class = "PriceClass_100"  # PriceClass_100 (cheapest), PriceClass_200, PriceClass_All
cf_default_ttl        = 3600               # 1 hour
cf_max_ttl            = 86400              # 24 hours
cf_min_ttl            = 0

# DNS Configuration: Using external DNS provider (GoDaddy, etc.)
# After deployment, get the CloudFront domain from Terraform outputs
# Create CNAME record in your DNS provider pointing to the CloudFront domain

# S3 documents
index_document = "index.html"
error_document = "404.html"
